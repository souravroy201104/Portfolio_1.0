# ─── Sourav Roy Portfolio — Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Site metadata (used in og:image generation etc.)
NEXT_PUBLIC_SITE_URL=https://souravroy.dev
NEXT_PUBLIC_SITE_NAME="Sourav Roy"

# Contact form — if you wire up an email service (e.g. Resend, SendGrid)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_TO_EMAIL=sourav@example.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
